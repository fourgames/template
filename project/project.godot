; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Template Four Games"
run/main_scene="uid://bytxkqqg13lxf"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/stretch_mode=0
boot_splash/use_filter=false
config/icon="uid://brjow5a5u36de"

[audio]

buses/default_bus_layout="uid://ci61fr1dqsshd"

[autoload]

ControllerIcons="*uid://bbr0y7cmquuy6"
Shaker="*uid://camqu126o10w4"
PathManager="*uid://cwiwhdgjmooc7"
SignalManager="*uid://djm5fbcusol8f"
DataManager="*uid://big0hyuv70jxs"
AudioManager="*uid://im0jy8db1q6"
NodeManager="*uid://bi1cxrxhj70n3"
ControlManager="*uid://c1bgdvrlmjwpk"
SceneChanger="*uid://ba3qklkjfvc6o"
GameManager="*uid://d07rtwy8ry14o"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/DualEditor/plugin.cfg", "res://addons/GPUTrail-main/plugin.cfg", "res://addons/Todo_Manager/plugin.cfg", "res://addons/controller_icons/plugin.cfg", "res://addons/script-ide/plugin.cfg", "res://addons/shaker/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "yellow",
"res://components/": "blue",
"res://components/menues/": "red",
"res://core/": "red",
"res://features/": "green",
"res://public/": "orange",
"res://routes/": "pink",
"res://src/": "blue",
"res://src/app/": "red",
"res://src/components/": "green",
"res://src/components/menues/": "red",
"res://src/features/": "purple",
"res://src/routes/": "teal"
}

[global_group]

Player="Player is in this group used for fidning it efficiently"
Loot="if loot is in group"
Navigation=""
MenuAnimation=""
Enemy="Target group to find targets the player can target"

